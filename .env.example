# Swift Egypt - Environment Variables

# Backend (FastAPI)
DATABASE_URL=postgresql+asyncpg://swift:swift123@localhost:5432/swiftegypt
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
DEBUG=true

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase Push Notifications
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=swift-egypt-uploads
AWS_REGION=us-east-1

# AI Services
AI_SERVICE_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8002

# SMS / OTP
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=your-stripe-secret
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Admin Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Flutter Apps
CUSTOMER_APP_API_URL=http://localhost:8000/api/v1
DRIVER_APP_API_URL=http://localhost:8000/api/v1
